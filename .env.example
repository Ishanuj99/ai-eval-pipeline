# ---- Required ----
GEMINI_API_KEY=your_gemini_api_key_here

# ---- Database ----
DATABASE_URL=postgresql://evaluser:evalpass@localhost:5432/evaldb

# ---- Redis / Celery ----
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# ---- App settings ----
APP_ENV=development
API_HOST=0.0.0.0
API_PORT=8000
LOG_LEVEL=INFO

# ---- Evaluation ----
LLM_JUDGE_MODEL=claude-haiku-4-5-20251001
LATENCY_THRESHOLD_MS=1000
MIN_ANNOTATION_AGREEMENT=0.6
AUTO_SUGGEST_AFTER_N_EVALS=100
